Полный пример с обработкой ошибок:
php
use BM\Core\Database\Connection;

class PoemRepository {
    private $pdo;
    private $tableMapper;
    
    public function __construct() {
        $this->pdo = Connection::getInstance();
        $this->tableMapper = TableMapper::getInstance();
    }
    
    public function searchPoems($query, $poet_id = null) {
        try {
            // Базовый SQL с именованными плейсхолдерами
            $sql = "SELECT p.*, pt.short_name as poet_name 
                    FROM " . $this->tableMapper->get('poem') . " p
                    LEFT JOIN " . $this->tableMapper->get('poet') . " pt ON p.poet_id = pt.id
                    WHERE p.name LIKE :search";
            
            $params = [':search' => '%' . $query . '%'];
            
            if ($poet_id) {
                $sql .= " AND p.poet_id = :poet_id";
                $params[':poet_id'] = $poet_id;
            }
            
            $stmt = $this->pdo->prepare($sql);
            $stmt->execute($params);
            
            return $stmt->fetchAll(\PDO::FETCH_OBJ);
            
        } catch (\PDOException $e) {
            error_log('Database error: ' . $e->getMessage());
            return [];
        }
    }
}
